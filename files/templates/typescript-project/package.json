{
	"name": "change-me",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"lint": "prettier --check . && oxlint --type-aware && tsc --noEmit",
		"fix": "prettier --write . && oxlint --type-aware --fix",
		"start": "tsx src/index.ts",
		"dev": "tsx src/index.ts"
	},
	"devDependencies": {
		"@e18e/eslint-plugin": "0.5.0",
		"@rlly/pedantic": "0.4.1",
		"@types/node": "24.12.4",
		"oxlint": "1.67.0",
		"oxlint-tsgolint": "0.23.0",
		"prettier": "3.8.3",
		"tsx": "latest",
		"typescript": "6.0.3"
	},
	"packageManager": "pnpm@11.9.0",
	"volta": {
		"node": "24.15.0",
		"pnpm": "11.9.0"
	}
}
